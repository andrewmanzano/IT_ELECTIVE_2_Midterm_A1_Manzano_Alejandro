<section id="contact" class="py-5 mb-5">
    <div class="mb-4 text-center">
        <h2 class="fw-bold text-dark">Information</h2>
        <div class="mx-auto bg-primary rounded" style="width: 60px; height: 4px;"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="bg-white p-4 p-md-5 rounded border shadow-sm text-center">
                <div class="mb-4">
                    <p class="mb-1 fw-bold text-dark">Email Address:</p>
                    <p class="text-secondary mb-3">@ViewData["Email"]</p>

                    <p class="mb-1 fw-bold text-dark">Mobile Number:</p>
                    <p class="text-secondary">@ViewData["Number"]</p>
                </div>

                <div class="d-flex justify-content-center gap-4 fs-4 mb-4">
                    <a href="@ViewData["Github"] target="_blank" class="text-dark"><i class="bi bi-github"></i> GitHub</a>
                    <a href="@ViewData["Linkedin"] target="_blank" class="text-primary"><i class="bi bi-linkedin"></i> LinkedIn</a>
                    <a href="@ViewData["Facebook"] target="_blank" class="text-primary"><i class="bi bi-facebook"></i> Facebook</a>
                </div>

                <button class="btn btn-dark btn-lg px-4"><i class="bi bi-download me-2"></i> Download Resume</button>
            </div>
        </div>
    </div>
</section>