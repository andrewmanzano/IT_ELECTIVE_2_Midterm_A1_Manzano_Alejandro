<section id="skills" class="py-5">
    <!-- Centered Heading Section -->
    <div class="mb-4 d-flex flex-column align-items-center text-center">
        <h2 class="fw-bold text-dark">Skills</h2>
        <div class="rounded" style="width: 70px; height: 5px; background: linear-gradient(90deg, #4f46e5, #10b981);"></div>
    </div>

    <div class="row g-4">
        <!-- Designing -->
        <div class="col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm text-center p-3 text-white" style="background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);">
                <div class="card-body">
                    <div class="mb-2 text-warning"><i class="bi bi-palette fs-3"></i></div>
                    <h5 class="card-title fw-bold fs-6">Designing</h5>
                    <p class="card-text small mb-0" style="color: #e0e7ff;">@ViewData["Designing"]</p>
                </div>
            </div>
        </div>
        <!-- TroubleShooting -->
        <div class="col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm text-center p-3 text-white" style="background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%);">
                <div class="card-body">
                    <div class="mb-2 text-warning"><i class="bi bi-bug fs-3"></i></div>
                    <h5 class="card-title fw-bold fs-6">Troubleshooting</h5>
                    <p class="card-text small mb-0" style="color: #e0f2fe;">@ViewData["Troubleshooting"]</p>
                </div>
            </div>
        </div>
        <!-- Problem Solving -->
        <div class="col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm text-center p-3 text-white" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%);">
                <div class="card-body">
                    <div class="mb-2 text-warning"><i class="bi bi-lightning-charge fs-3"></i></div>
                    <h5 class="card-title fw-bold fs-6">Problem Solving</h5>
                    <p class="card-text small mb-0" style="color: #ecfdf5;">@ViewData["Problem Solving"]</p>
                </div>
            </div>
        </div>
        <!-- Analytical Thinking -->
        <div class="col-sm-6 col-md-3">
            <div class="card h-100 border-0 shadow-sm text-center p-3 text-white" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
                <div class="card-body">
                    <div class="mb-2 text-dark"><i class="bi bi-graph-up-arrow fs-3"></i></div>
                    <h5 class="card-title fw-bold fs-6">Analytical Thinking</h5>
                    <p class="card-text small mb-0" style="color: #fef3c7;">@ViewData["Analytical Thinker"]</p>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="my-5"><hr class="text-muted opacity-25" /></div>