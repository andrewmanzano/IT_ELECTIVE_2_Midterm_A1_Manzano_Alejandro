<section id="projects" class="py-5 bg-light">
    <div class="container">
        <div class="mb-5 d-flex flex-column align-items-center text-center">
            <h2 class="fw-bold text-dark">Projects</h2>
            <div class="rounded" style="width: 70px; height: 5px; background: linear-gradient(90deg, #4f46e5, #10b981);"></div>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Project 1: Retail Discount System - subtle blue hue -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-primary-subtle">
                    <div style="height: 200px; overflow: hidden;">
                        <img src="~/Image/discounts.png" class="w-100 h-100" style="object-fit: cover;" alt="Retail Discount System screenshot" />
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div>
                            <h5 class="card-title fw-bold text-primary-emphasis mb-3">Retail Discount System</h5>
                            <p class="card-text text-secondary small mb-4">@ViewData["Discount"]</p>
                            <p class="text-muted small"><span class="fw-semibold text-dark">Technologies:</span> Relational Database Design, SQL, Data Logic</p>
                        </div>
                        <button class="btn btn-outline-primary w-100 mt-4 rounded-pill">View Details</button>
                    </div>
                </div>
            </div>

            <!-- Project 2: Loan Application System - simple light/white hue -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-light">
                    <div style="height: 200px; overflow: hidden;">
                        <img src="~/Image/Login.png" class="w-100 h-100" style="object-fit: cover;" alt="Loan Application System screenshot" />
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div>
                            <h5 class="card-title fw-bold text-dark mb-3">Loan Application System</h5>
                            <p class="card-text text-secondary small mb-4">@ViewData["Login System"]</p>
                            <p class="text-muted small"><span class="fw-semibold text-dark">Technologies:</span> Visual Basic, Windows Forms, UI</p>
                        </div>
                        <button class="btn btn-outline-secondary w-100 mt-4 rounded-pill">View Details</button>
                    </div>
                </div>
            </div>

            <!-- Project 3: Parking Slot System - subtle yellow/gold hue -->
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-warning-subtle">
                    <div style="height: 200px; overflow: hidden;">
                        <img src="~/Image/Parking.png" class="w-100 h-100" style="object-fit: cover;" alt="Parking Slot System screenshot" />
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div>
                            <h5 class="card-title fw-bold text-warning-emphasis mb-3">Parking Slot System</h5>
                            <p class="card-text text-secondary small mb-4">@ViewData["Parking System"]</p>
                            <p class="text-muted small"><span class="fw-semibold text-dark">Technologies:</span> Python, CustomTkinter, Database, OOP</p>
                        </div>
                        <button class="btn btn-outline-warning w-100 mt-4 rounded-pill">View Details</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="my-5"><hr class="text-muted opacity-25" /></div>