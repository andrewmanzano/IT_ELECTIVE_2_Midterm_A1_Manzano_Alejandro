<!-- ==========================================
     1. HOME SECTION
     ========================================== -->
<div class="text-center">
    <h1 class="display-4">Welcome to my page!</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

<div class="row align-items-center py-5">
    <div class="col-md-7">
        <hr style="border: 2px solid #0d6efd; width: 350px; opacity: 1;" class="mb-4">
        <h1 class="fw-bold text-dark display-5">Alejandro L. Manzano</h1>
        <h4 class="text-primary mb-4">Software Developer</h4>
        <p class="text-secondary fs-5 mb-4">
            Welcome to my digital space. I specialize in designing, user-friendly layouts and structuring responsive web applications with ASP.NET Core.
        </p>
        <div class="d-flex gap-2">
            <a href="#projects" class="btn btn-primary px-4">View Projects</a>
