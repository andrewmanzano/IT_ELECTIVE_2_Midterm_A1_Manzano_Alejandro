<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - IT_ELECTIVE_2_Midterm_A1</title>
		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
		<link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
	</head>
	<body>
		<!-- Main outer flexbox layout container -->
		<div class="d-flex flex-column flex-md-row min-vh-100">

			<!-- SIDEBAR / TOP NAVIGATION PANEL -->
			<header class="bg-white border-end p-3 box-shadow d-flex flex-column" style="min-width: 240px;">
				<div class="d-flex flex-row flex-md-column justify-content-between align-items-center align-items-md-start w-100">
					<!-- Name Logo -->
					<a class="navbar-brand text-uppercase fw-semibold fs-4 mb-0 mb-md-3" asp-area="" asp-controller="Home" asp-action="Index">MANZANO</a>

					<!-- Toggle Button (Only visible on small mobile viewports) -->
					<button class="navbar-toggler d-md-none border p-2 rounded" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu" aria-expanded="false" aria-label="Toggle navigation">
						<span class="navbar-toggler-icon"></span>
					</button>
				</div>

					<!-- Collapsible Sidebar Menu links -->
					<div class="collapse d-md-flex flex-column flex-grow-1 w-100" id="sidebarMenu">
						<ul class="nav flex-column gap-2 w-100 mt-3 mt-md-0">
							<li class="nav-item">
								<a class="nav-link text-dark p-2" href="#home">Home</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark p-2" href="#about">About Me</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark p-2" href="#skills">Skills</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark p-2" href="#projects">Projects</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark p-2" href="#contact">Contact</a>
							</li>
						</ul>
					</div>
				</header>

			<!-- MAIN WINDOW/CONTENT AREA -->
			<main class="flex-grow-1 p-4">
				@RenderBody()
			</main>

		</div>

		<!-- Script references -->
		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		<script src="~/js/site.js" asp-append-version="true"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>
