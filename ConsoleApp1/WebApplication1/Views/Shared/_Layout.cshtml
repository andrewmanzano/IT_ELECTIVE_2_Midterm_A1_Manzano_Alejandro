<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>@ViewData["Title"] - IT_ELECTIVE_2_Midterm_A1</title>
		<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
		<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
		<link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
	</head>
	<body>
		<header>
			<!-- Top Navigation Bar matching your screenshot -->
			<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
				<div class="container-fluid">
					<!-- Name Logo on the Left -->
					<a class="navbar-brand text-uppercase fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">MANZANO</a>

					<!-- Hamburger Menu Button on the Right -->
					<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
							aria-expanded="false" aria-label="Toggle navigation">
						<span class="navbar-toggler-icon"></span>
					</button>

					<!-- Navigation links (Collapsible on mobile) -->
					<div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
						<ul class="navbar-nav flex-grow-1 justify-content-end gap-2">
							<li class="nav-item">
								<a class="nav-link text-dark" href="#home">Home</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark" href="#about">About Me</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark" href="#skills">Skills</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark" href="#projects">Projects</a>
							</li>
							<li class="nav-item">
								<a class="nav-link text-dark" href="#contact">Contact</a>
							</li>
						</ul>
					</div>
				</div>
			</nav>
		</header>

		<!-- Content Container -->
		<div class="container">
			<main role="main" class="pb-3">
				@RenderBody()
			</main>
		</div>

		<!-- Sticky Bottom Footer matching your screenshot -->
		<footer class="border-top footer text-muted bg-white py-3 mt-auto">
			<div class="container">
				© 2026 - WebApplication1 - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
			</div>
		</footer>

		<script src="~/lib/jquery/dist/jquery.min.js"></script>
		<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
		<script src="~/js/site.js" asp-append-version="true"></script>
		@await RenderSectionAsync("Scripts", required: false)
	</body>
</html>